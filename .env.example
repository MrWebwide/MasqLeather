# ═══════════════════════════════════════════════════════
# MASQ Leather — Environment Configuration Template
# ═══════════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyalayın ve gerçek değerleri girin.
# cp .env.example .env
# ═══════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────
DB_HOST=localhost
DB_NAME=masq
DB_USER=root
DB_PASS=

# ─── Site ─────────────────────────────────────────────
SITE_URL=https://masqleather.com/
UPLOAD_FOLDER=/resimler/

# ─── SMTP / Email ────────────────────────────────────
SMTP_HOST=mail.masqleather.com
SMTP_USER=info@masqleather.com
SMTP_PASS=your_smtp_password_here
SMTP_SECURE=ssl
SMTP_PORT=465

MAIL_FROM_ADDRESS=info@masqleather.com
MAIL_FROM_NAME=Masq Leather
ADMIN_EMAIL=admin@example.com

# ─── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
